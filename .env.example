# =========================
# MongoDB Configuration
# =========================
# URL for MongoDB connection. Format: mongodb://username:password@host:port/database?authSource=admin
# Default: local MongoDB with credentials
MONGODB_URL=mongodb://admin:admin123%20@localhost:27017/video_detection_db?authSource=admin

# Database name for storing detection results and known persons
DATABASE_NAME=video_detection_db

# =========================
# Application Settings
# =========================
# Directory for uploaded video files (used in API)
UPLOAD_DIR=uploads

# Directory for saving detected person crops from videos
OUTPUT_DIR=output/detected

# Temporary directory for processing video files (download cache, temp processing)
TEMP_DIR=temp

# =========================
# Model Paths (Only Load from models/ Directory)
# =========================
# Path to YOLO model for person detection
# Must be located in models/ directory (no external downloads allowed)
YOLO_MODEL_PATH=models/yolov8_person_detection.pt

# Path to ViT model for feature extraction
# Must be located in models/ directory (no external downloads allowed)
VIT_MODEL_PATH=models/vit_final_model.pth

# =========================
# Detection Settings
# =========================
# Confidence threshold for YOLO detections (0-1)
# Only detections above this score are processed
CONFIDENCE_THRESHOLD=0.75

# Similarity threshold for identifying known persons (0-1)
# Cosine similarity must exceed this value to match a known person
# Lower = more lenient matching, higher = stricter matching
KNOWN_PERSON_THRESHOLD=0.95

# Frame extraction rate in FPS (frames per second)
# Example: 2 = extract 2 frames per second from video
FRAME_EXTRACTION_FPS=2

# =========================
# Server Settings
# =========================
# API server host address
HOST=0.0.0.0

# API server port
PORT=8000

# Enable hot reload (development only, disable for production)
RELOAD=true

# =========================
# GPU Settings
# =========================
# Which GPU devices to use (0-indexed)
# Example: "0" = GPU 0, "0,1" = GPU 0 and 1
# Leave empty or comment out to use CPU only
CUDA_VISIBLE_DEVICES=0

